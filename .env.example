# Example env — copy to `.env` locally or set in Render dashboard (never commit `.env`)

# --- Email (required for real daily brief to inbox) ---
BRIEF_RECIPIENT_EMAIL=vpeetla.ai@gmail.com
# Resend: https://resend.com/api-keys — create key, paste here in Render only
RESEND_API_KEY=re_your_key_here
# Sender must be verified in Resend (domain or onboarding address)
BRIEF_FROM_EMAIL=onboarding@resend.dev

# --- Governance (optional for MVP; enable when AegisAI API is live) ---
AEGISAI_API_BASE_URL=
AEGISAI_GATEWAY_ENABLED=false
AEGISAI_GATEWAY_FAIL_OPEN=true

# --- Run tuning ---
MIN_DELTA_ITEMS=3
MAX_ITEMS_PER_SOURCE=12

# --- Observability (optional — traces export to Langfuse Cloud when set) ---
# https://cloud.langfuse.com → Project → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
